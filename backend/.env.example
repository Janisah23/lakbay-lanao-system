# ==========================================
# FIREBASE CONFIGURATION
# ==========================================
# Obtain these from: 
# 1. Go to Firebase Console (console.firebase.google.com)
# 2. Select your Project > Project Settings (gear icon)
# 3. Scroll down to "Your apps" > Firebase SDK snippet > Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ==========================================
# GOOGLE GEMINI AI
# ==========================================
# Obtain this from:
# 1. Go to Google AI Studio (aistudio.google.com/app/apikey)
# 2. Click "Create API key"
GEMINI_API_KEY=

# ==========================================
# CHROMADB CLOUD (KNOWLEDGE BASE)
# ==========================================
# Obtain these from:
# 1. Go to ChromaDB Cloud (trychroma.com)
# 2. Create a Database.
# 3. CHROMA_DATABASE is the 'Database name' you set.
# 4. Under 'Connection details', you'll find Host and Tenant IDs.
# 5. Under 'Credentials', generate a new API key.
CHROMA_HOST=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=